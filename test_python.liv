fn main():
    import py "math" as math
    import py "json" as json

    print("math module:")
    print(math)
    
    let res = math.cos(2)
    print("result:")
    print(res)

    let parsed = json.loads("{\"hello\": \"world\", \"val\": 42}")
    let hw = parsed.get("hello")
    print("HW:")
    print(hw)

main()
